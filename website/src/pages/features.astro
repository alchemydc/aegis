---
import Base from '../layouts/Base.astro';

const features = [
  {
    title: 'Real-Time Ad Blocking',
    description:
      'adblocked.ai detects sponsored and promoted elements in AI conversations and removes them before they reach you. No lag, no manual intervention.',
  },
  {
    title: 'One-Click Installation',
    description:
      'Install once and run instantly. No setup wizard, no complicated configuration, and no maintenance overhead. It just works.',
  },
  {
    title: 'Device-Local Privacy',
    description:
      'adblocked.ai works in your browser, not on our servers. Conversations stay on your device and out of third-party pipelines.',
  },
];

const roadmap = [
  {
    phase: 'Now',
    title: 'Strip the Ads',
    description: 'Browser extension that blocks ads and promoted content in AI conversations. Starting with ChatGPT.',
  },
  {
    phase: 'Next',
    title: 'Surface the Influence',
    description: 'Transparency layer that reveals when and how AI outputs are shaped by commercial interests.',
  },
  {
    phase: 'Vision',
    title: 'Set Your Boundaries',
    description: 'User-side constraints and preferences that give you control over how AI behaves on your behalf.',
  },
];
---

<Base title="adblocked.ai Features" description="Explore the features behind ad-free, user-controlled AI conversations.">
  <section class="bg-off-white py-20 dark:bg-charcoal">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold text-navy dark:text-white">Features</h1>
      <p class="mt-4 max-w-2xl text-base text-gray-muted">
        adblocked.ai is built for focused AI conversations: fast, private, and ad-free by default.
      </p>

      <div class="mt-12 space-y-6">
        {features.map((feature) => (
          <article class="reveal grid gap-6 rounded-xl border border-border-light bg-white p-6 md:grid-cols-2 md:items-center dark:border-border-light/20 dark:bg-charcoal/50">
            <div class="aspect-video rounded-lg border border-border-light bg-border-light/60 dark:border-border-light/20 dark:bg-charcoal"></div>
            <div>
              <h2 class="text-2xl font-semibold text-navy dark:text-white">{feature.title}</h2>
              <p class="mt-3 text-base leading-7 text-gray-muted">{feature.description}</p>
            </div>
          </article>
        ))}
      </div>

      <div class="mt-20">
        <h2 class="text-3xl font-bold text-navy dark:text-white">What's Next</h2>
        <p class="mt-3 text-base text-gray-muted">Ad blocking is the starting point. Here's where we're headed.</p>

        <div class="mt-8 grid gap-6 md:grid-cols-3">
          {roadmap.map((item) => (
            <article class="reveal rounded-xl border border-border-light bg-white p-6 dark:border-border-light/20 dark:bg-charcoal/50">
              <p class="text-sm font-semibold text-cyan">{item.phase}</p>
              <h3 class="mt-2 text-lg font-semibold text-navy dark:text-white">{item.title}</h3>
              <p class="mt-2 text-sm leading-6 text-gray-muted">{item.description}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>
</Base>
