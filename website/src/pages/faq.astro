---
import Base from '../layouts/Base.astro';
import FAQAccordion from '../components/FAQAccordion.jsx';

const faqData = [
  {
    question: 'What does adblocked.ai actually do today?',
    answer:
      'It\'s a browser extension that detects and removes ads, sponsored content, and promoted suggestions from AI chat interfaces. Currently supports ChatGPT, with more platforms planned.',
  },
  {
    question: 'Is this just an ad blocker?',
    answer:
      'Ad blocking is where it starts. The larger goal is a user-side control layer for AI\u2014surfacing commercial influence, enabling user-set boundaries, and giving you visibility into how AI responses are shaped.',
  },
  {
    question: 'What data do you collect?',
    answer: 'None. adblocked.ai runs locally in your browser with no analytics, no tracking, and no server-side logging.',
  },
  {
    question: 'Does it slow down ChatGPT?',
    answer: 'No. The extension operates with negligible overhead and removes ad elements before they render.',
  },
  {
    question: 'Is it free and open source?',
    answer: 'Yes and yes. The core tool will remain free and open source.',
  },
];
---

<Base title="adblocked.ai FAQ" description="Answers to common questions about adblocked.ai privacy, compatibility, and setup.">
  <section class="bg-off-white py-20 dark:bg-charcoal">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h1 class="text-center text-4xl font-bold text-navy dark:text-white">Frequently Asked Questions</h1>
      <p class="mt-4 text-center text-base text-gray-muted">
        Practical answers before you install.
      </p>

      <div class="mt-10 reveal">
        <FAQAccordion client:load items={faqData} />
      </div>
    </div>
  </section>
</Base>
