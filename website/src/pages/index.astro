---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import ProblemStatement from '../components/ProblemStatement.astro';
import FeaturesSection from '../components/FeaturesSection.astro';
import HowItWorks from '../components/HowItWorks.astro';
import TrustSection from '../components/TrustSection.astro';
import FAQAccordion from '../components/FAQAccordion.jsx';
import FinalCTA from '../components/FinalCTA.astro';

const faqData = [
  {
    question: 'What does adblocked.ai actually do today?',
    answer:
      'It\'s a browser extension that detects and removes ads, sponsored content, and promoted suggestions from AI chat interfaces. Currently supports ChatGPT, with more platforms planned.',
  },
  {
    question: 'Is this just an ad blocker?',
    answer:
      'Ad blocking is where it starts. The larger goal is a user-side control layer for AI\u2014surfacing commercial influence, enabling user-set boundaries, and giving you visibility into how AI responses are shaped.',
  },
  {
    question: 'What data do you collect?',
    answer:
      'None. adblocked.ai runs locally in your browser with no analytics, no tracking, and no server-side logging.',
  },
  {
    question: 'Does it slow down ChatGPT?',
    answer:
      'No. The extension operates with negligible overhead and removes ad elements before they render.',
  },
  {
    question: 'Is it free and open source?',
    answer:
      'Yes and yes. The core tool will remain free and open source.',
  },
];

---

<Base
  title="adblocked.ai — Block Ads in AI. Then See Everything Else."
  description="adblocked.ai is a user-side layer that starts by blocking ads in AI conversations and builds toward full visibility and control."
>
  <Hero />
  <ProblemStatement />
  <FeaturesSection />
  <HowItWorks />
  <TrustSection />

  <section id="faq" class="bg-off-white py-20 dark:bg-charcoal" aria-labelledby="faq-heading">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 id="faq-heading" class="text-center text-3xl font-bold text-navy dark:text-white">Frequently Asked Questions</h2>
      <div class="mt-8 reveal">
        <FAQAccordion client:load items={faqData} />
      </div>
    </div>
  </section>

  <FinalCTA />
</Base>
