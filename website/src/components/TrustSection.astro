---
const trustItems = [
  {
    icon: '🔒',
    title: 'No Data Collection',
    description: 'adblocked.ai runs entirely on your device. Your conversations never leave your browser. We can\'t see what you say even if we wanted to.',
  },
  {
    icon: '🧩',
    title: 'Open Source',
    description: 'The code is public. Every decision the extension makes is auditable. A tool that claims to surface hidden influence cannot itself be a black box.',
  },
  {
    icon: '✅',
    title: 'Privacy by Design',
    description: 'No analytics, no tracking, no server-side anything. Built around GDPR principles as a design choice, not a compliance checkbox.',
  },
];
---

<section id="privacy" class="bg-off-white py-20 dark:bg-charcoal" aria-labelledby="privacy-heading">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <h2 id="privacy-heading" class="text-center text-3xl font-bold text-navy dark:text-white">Why This Is Open Source</h2>

    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {trustItems.map((item) => (
        <article class="reveal rounded-xl border border-border-light bg-white p-6 dark:border-border-light/20 dark:bg-charcoal/50">
          <p class="text-2xl" aria-hidden="true">{item.icon}</p>
          <h3 class="mt-4 text-lg font-semibold text-navy dark:text-white">{item.title}</h3>
          <p class="mt-2 text-sm leading-6 text-gray-muted">{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
