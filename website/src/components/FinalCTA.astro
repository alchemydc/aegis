---
import CTAButton from './CTAButton.astro';
---

<section class="bg-navy py-20 text-center" aria-labelledby="final-cta-heading">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
    <h2 id="final-cta-heading" class="text-2xl font-bold leading-snug text-white sm:text-3xl">
      The last version of the internet trained us to accept invisible manipulation.
    </h2>
    <p class="mt-4 text-base text-off-white/80">
      This version will go further&mdash;unless something exists to counter it.
    </p>
    <div class="mt-8 flex justify-center">
      <CTAButton href="/download" size="lg">Install the Extension</CTAButton>
    </div>
  </div>
</section>
